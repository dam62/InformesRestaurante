<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:InformesRestaurante.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InformesRestaurante.Views.InformesRestaurante.InformeEmpleados"
             x:DataType="viewModels:MainWindowViewModel">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    <Grid ColumnDefinitions="320,*"
          Margin="20"
          ShowGridLines="False">

        <!-- IZQUIERDA: DATOS -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke"
                BorderBrush="LightGray"
                BorderThickness="1">

            <StackPanel Spacing="16">

                <TextBlock Text="EMPLEADOS POR PUESTO"
                           FontSize="16"
                           FontWeight="Bold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Puesto de trabajo"
                               FontSize="13"
                               Foreground="DimGray" />
                    <ComboBox PlaceholderText="Elige el puesto de trabajo" Name="ComboEm"
                              ItemsSource="{Binding ListaPuestos}" />
                </StackPanel>

                <Separator />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    
                    <Button HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="Crimson"
                            IsVisible="{Binding SeMuestraPDF}"
                            Command="{Binding OcultarPdfCommand}"
                            Content="Ocultar PDF" />

                    <Button Content="Generar informe"
                            Width="150"
                            Height="36"
                            Command="{Binding GenerarPDFCategoriaPlatoCommand}"
                            CommandParameter="{Binding ElementName=ComboEm, Path=SelectedItem}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Text="Este informe mostrara la información de todos los empleados que trabajen en el puesto que has seleccionado.&#10;&#10;
El informe debe mostrar:&#10;
- Identificador del empleado&#10;
- Nombre del empleado&#10;
- Salario que cobra&#10;
- Fecha de contratación"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DERECHA: VISOR PDF -->
        <Border Grid.Column="1"
                Padding="10"
                CornerRadius="8"
                Background="White"
                BorderBrush="LightGray"
                BorderThickness="1">
            
            <WebView Url="{Binding Url}"
                     IsVisible="{Binding SeMuestraPDF}" />
        </Border>
    </Grid>
</UserControl>
