<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:InformesRestaurante.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InformesRestaurante.Views.InformesLineas.InformeCategoriasPlatos"
             x:DataType="viewModels:MainWindowViewModel">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    <Grid ColumnDefinitions="340,*"
          Margin="20"
          ShowGridLines="False">

        <!-- IZQUIERDA: DATOS -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke"
                BorderBrush="LightGray"
                BorderThickness="1">

            <StackPanel Spacing="16">

                <TextBlock Text="INFORME CATEGORIA POR PLATO"
                           FontSize="16"
                           FontWeight="Bold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Categoria plato"
                               FontSize="13"
                               Foreground="DimGray" />
                    <ComboBox PlaceholderText="Elige categoria" Name="ComboCat"
                              ItemsSource="{Binding ListaCategorias}" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal"
                            Spacing="12">

                    <StackPanel Spacing="4"
                                Width="150">
                        <TextBlock Text="Fecha inicio"
                                   FontSize="13"
                                   Foreground="DimGray" />
                        <DatePicker Width="155" SelectedDate="{Binding FechaInicio}" />
                    </StackPanel>

                    <StackPanel Spacing="4"
                                Width="150">
                        <TextBlock Text="Fecha fin"
                                   FontSize="13"
                                   Foreground="DimGray" />
                        <DatePicker Width="155" SelectedDate="{Binding FechaFinal}" />
                    </StackPanel>
                </StackPanel>

                <Separator />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    
                    <Button HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="Crimson"
                            IsVisible="{Binding SeMuestraPDF}"
                            Command="{Binding OcultarPdfCommand}"
                            Content="Ocultar PDF" />

                    <Button Content="Generar informe"
                            Width="150"
                            Height="36"
                            Command="{Binding GenerarPDFCategoriaPlatoCommand}"
                            CommandParameter="{Binding ElementName=ComboCat, Path=SelectedItem}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Text="Este informe permite consultar las ventas de platos según su categoría, aplicando fechas.&#10;&#10;
El usuario puede seleccionar una categoría de plato y un rango de fechas específico."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DERECHA: VISOR PDF -->
        <Border Grid.Column="1"
                Padding="10"
                CornerRadius="8"
                Background="White"
                BorderBrush="LightGray"
                BorderThickness="1">
            
            <WebView Url="{Binding Url}"
                     IsVisible="{Binding SeMuestraPDF}" />
        </Border>
    </Grid>
</UserControl>