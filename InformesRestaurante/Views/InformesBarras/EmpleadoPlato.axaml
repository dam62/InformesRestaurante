<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:InformesRestaurante.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="InformesRestaurante.Views.InformesBarras.EmpleadoPlato"
             x:DataType="viewModels:MainWindowViewModel">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="320,*"
          Margin="20"
          ShowGridLines="False">

        <!-- IZQUIERDA: DATOS -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke"
                BorderBrush="LightGray"
                BorderThickness="1">

            <StackPanel Spacing="16">

                <TextBlock Text="INFORMACIÓN EMPLEADO Y PLATOS"
                           FontSize="16"
                           FontWeight="Bold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Empleados"
                               FontSize="13"
                               Foreground="DimGray" />
                    <AutoCompleteBox IsTextCompletionEnabled="False" Name="AutoCompleteEmpleados"
                                     FilterMode="None" MinimumPrefixLength="1"
                                     Background="White"
                                     MaxDropDownHeight="120" Watermark="Nombre de empleado"
                                     Width="150" Margin="10"
                                     ItemsSource="{Binding ListaEmpleados}"
                                     Text="{Binding Filtro}">
                        <Interaction.Behaviors>
                            <EventTriggerBehavior EventName="TextChanged">
                                <InvokeCommandAction Command="{Binding ObtenerEmpleadosPorFiltroCommand}"/>
                            </EventTriggerBehavior>
                        </Interaction.Behaviors>
                    </AutoCompleteBox>
                </StackPanel>

                <Separator />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    
                    <Button HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="Crimson"
                            IsVisible="{Binding SeMuestraPDF}"
                            Command="{Binding OcultarPdfCommand}"
                            Content="Ocultar PDF" />

                    <Button Content="Generar informe"
                            Width="150"
                            Height="36"
                            Command="{Binding MostrarPDFEmpleadosCommand}"
                            CommandParameter="{Binding ElementName=AutoCompleteEmpleados, Path=SelectedItem}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Text="Este informe permite consultar los platos gestionados por un empleado específico.&#10;&#10;
El usuario debe insertar el nombre del empleado para ver un resumen de su actividad."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DERECHA: VISOR PDF -->
        <Border Grid.Column="1"
                Padding="10"
                CornerRadius="8"
                Background="White"
                BorderBrush="LightGray"
                BorderThickness="1">
            
            <WebView Url="{Binding Url}"
                     IsVisible="{Binding SeMuestraPDF}" />
        </Border>
    </Grid>
</UserControl>
